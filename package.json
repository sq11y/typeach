{
  "name": "@typeach/docs",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "accessibility",
    "components",
    "scss",
    "theme",
    "vue"
  ],
  "homepage": "https://sq11y.github.io/typeach/",
  "repository": "github:sq11y/typeach",
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && pnpm test && pnpm build",
    "dev": "vp run --filter './**' --filter '!.' dev",
    "test": "vp run --filter './**' --filter '!.' test",
    "docs:dev": "do11y",
    "docs:preview": "do11y preview",
    "docs:build": "do11y build",
    "build": "vp run --filter './**' --filter '!.' build",
    "prepare": "vp config",
    "lint": "pnpm eslint && pnpm stylelint '**/*.{css,scss,vue}'"
  },
  "dependencies": {
    "@typeach/core": "workspace:*",
    "@typeach/theme": "workspace:*",
    "@vueuse/core": "catalog:",
    "change-case": "^5.4.4",
    "pinia": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "do11y": "^0.5.14",
    "eslint": "^10.6.0",
    "eslint-config-sq11y": "^0.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "shiki": "^4.2.0",
    "stylelint": "^17.14.0",
    "stylelint-config-sq11y": "^0.0.2",
    "vite-plus": "catalog:",
    "vite-svg-loader": "^5.1.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.6.0"
}
