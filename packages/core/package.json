{
  "name": "@typeach/core",
  "version": "0.0.5",
  "description": "Component library for Vue.",
  "keywords": [
    "accessibility",
    "components",
    "vue"
  ],
  "homepage": "https://sq11y.github.io/typeach/",
  "license": "MIT",
  "repository": "github:sq11y/typeach",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/typeach.umd.cjs",
  "module": "./dist/typeach.js",
  "exports": {
    ".": {
      "import": "./dist/typeach.js",
      "require": "./dist/typeach.umd.cjs"
    }
  },
  "scripts": {
    "dev": "playwright test -c playwright-ct.config.ts --ui && rimraf .tmp",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vp build",
    "type-check": "vue-tsc --build",
    "test": "playwright test -c playwright-ct.config.ts"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@vueuse/core": "catalog:",
    "change-case": "^5.4.4"
  },
  "devDependencies": {
    "@playwright/experimental-ct-vue": "^1.60.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-dom": "^3.5.38",
    "@vue/tsconfig": "^0.9.1",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^2.1.5",
    "typescript": "~6.0.0",
    "vite": "catalog:",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plus": "catalog:",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "pinia": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  }
}
